{
  "name": "doc-freshness-checker",
  "version": "0.0.0-development",
  "description": "Universal documentation freshness checker - validates documentation accuracy against actual codebase",
  "homepage": "https://github.com/cosmocoder/doc-freshness-checker#readme",
  "bugs": {
    "url": "https://github.com/cosmocoder/doc-freshness-checker/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmocoder/doc-freshness-checker.git"
  },
  "license": "MIT",
  "author": "cosmocoder",
  "type": "module",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "doc-freshness": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --noEmit",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "prettier --write src/",
    "prettier:ci": "prettier --check src/",
    "docs:check": "node dist/cli.js",
    "docs:check:json": "node dist/cli.js --reporter json --output reports/doc-freshness.json",
    "prepare": "husky",
    "create-release": "semantic-release"
  },
  "keywords": [
    "documentation",
    "freshness",
    "validation",
    "docs",
    "checker",
    "stale",
    "lint",
    "markdown",
    "ci",
    "devops"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "engine-strict": true,
  "dependencies": {
    "commander": "14.0.3",
    "fastembed": "2.1.0",
    "glob": "13.0.6",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.2",
    "@types/node": "25.6.0",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "9.39.2",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "lint-staged": {
    "src/**/*.md": [
      "npm run prettier"
    ],
    "src/**/*.{js,ts}": [
      "npm run lint:fix",
      "npm run prettier"
    ]
  }
}
